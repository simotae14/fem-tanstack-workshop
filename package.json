    "drizzle-kit": "^1.0.0-beta.15-859cf75",
    "drizzle-orm": "^1.0.0-beta.15-859cf75",
    "framer-motion": "^12.35.0",
    "immer": "^11.1.4",
    "lodash": "^4.17.23",
    "lucide-react": "^0.545.0",
    "nitro": "npm:nitro-nightly@latest",
    "pg": "^8.18.0",
    "radix-ui": "^1.4.3",
    "react": "^19.2.0",
    "react-day-picker": "^9.14.0",
    "react-dom": "^19.2.0",
    "sonner": "^2.0.7",
